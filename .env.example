# Copy to .env locally if you want, but do not commit real values.

# Stremio probes can use either STREMIO_AUTH_KEY or email/password.
STREMIO_AUTH_KEY=
STREMIO_EMAIL=
STREMIO_PASSWORD=
# Safety guard: when set, all Stremio probes fail if the auth key belongs to a different user.
STREMIO_EXPECTED_USER_ID=
STREMIO_API_BASE=https://api.strem.io
STREMIO_LIKES_BASE=https://likes.stremio.com/api

# Trakt probes require a Trakt application and an OAuth access token.
TRAKT_CLIENT_ID=
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=
TRAKT_DEVICE_CODE=
# Safety guard: when set, Trakt account probes fail if OAuth belongs to a different username.
TRAKT_EXPECTED_USERNAME=
TRAKT_API_BASE=https://api.trakt.tv

# Please include a useful contact when making repeated API calls.
SYNCIO_USER_AGENT=SYNCIO/0.0.0 research

# Optional reusable test targets.
SYNCIO_TEST_MOVIE_ID=
SYNCIO_TEST_MOVIE_NAME=
SYNCIO_TEST_MOVIE_YEAR=
SYNCIO_TEST_SHOW_ID=
SYNCIO_TEST_SHOW_NAME=
SYNCIO_TEST_SHOW_YEAR=
